{
  "manifest_version": 3,
  "name": "SmartTools Tabs Importer",
  "version": "1.0.0",
  "description": "Import currently open Chrome/Edge tabs into SmartTools.",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["pending-import.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Import open tabs to SmartTools",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
