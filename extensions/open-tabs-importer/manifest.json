{
  "manifest_version": 3,
  "name": "SmartTools Open Tabs Importer",
  "version": "1.0.0",
  "description": "Import currently open Chrome/Edge tabs into SmartTools.",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Import open tabs to SmartTools",
    "default_popup": "popup.html"
  }
}
